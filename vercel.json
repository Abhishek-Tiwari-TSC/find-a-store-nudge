{
    "version": 2,
    "builds": [
        {
            "src": "backend/app.js",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build"
            }
        }
    ],
    "routes": [
        {
            "src": "/collect",
            "dest": "backend/app.js"
        },
        {
            "src": "/admin/(.*)",
            "dest": "backend/app.js"
        },
        {
            "src": "/health",
            "dest": "backend/app.js"
        },
        {
            "src": "/(.*)",
            "dest": "frontend/build/$1"
        }
    ]
}